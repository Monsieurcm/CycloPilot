{
  "name": "@cyclopilot/fit-engine",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "FIT file parsing and processing",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && pnpm test",
    "lint": "eslint src/**/*.ts",
    "test": "node --test dist/validation/*.test.js",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "validate:fit:technical": "node dist/validation/runTechnicalValidation.js",
    "validate:fit:platform": "node dist/validation/runPlatformValidation.js"
  },
  "dependencies": {
    "@cyclopilot/shared": "workspace:*",
    "fit-decoder": "^1.0.5",
    "fit-encoder": "0.1.5",
    "fit-file-parser": "3.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "typescript": "^5.8.3"
  }
}
